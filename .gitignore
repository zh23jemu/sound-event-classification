# Python 本地虚拟环境与解释器缓存
.venv/
__pycache__/
*.py[cod]

# Python 测试、类型检查和格式化工具缓存
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Jupyter 本地检查点
.ipynb_checkpoints/

# 本地环境变量与敏感配置
.env
.env.*
!.env.example

# 编辑器和系统生成文件
.vscode/
.idea/
.DS_Store
Thumbs.db
~$*.docx

# 临时文件与运行缓存
*.tmp
*.temp
*.log

# 数据集原始文件通常体积较大，不直接纳入版本管理
data/

# 深度学习大模型权重和 checkpoint 默认不提交
*.pt
*.pth
*.ckpt
*.safetensors

# Slurm 运行日志属于本地/集群运行态
outputs/slurm/
